{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "calendar-api-backend", "run", "dev"],
      "port": 3001
    },
    {
      "name": "Frontend",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "calendar-api-frontend/node_modules/vite/bin/vite.js",
        "calendar-api-frontend",
        "--host"
      ],
      "port": 5173
    }
  ]
}
